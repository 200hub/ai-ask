{
  "name": "ai-ask",
  "type": "module",
  "version": "0.0.1-alpha.25",
  "packageManager": "pnpm@9.15.0",
  "description": "AI Ask - 一个简洁高效的AI问答助手",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "pnpm run test:frontend && pnpm run test:rust",
    "test:frontend": "vitest run",
    "test:rust": "cd src-tauri && cargo test",
    "lint": "pnpm run lint:frontend && pnpm run lint:rust",
    "lint:frontend": "eslint src",
    "lint:rust": "cd src-tauri && cargo fmt --check && cargo clippy -- -D warnings",
    "lint:fix": "pnpm run lint:frontend:fix && pnpm run lint:rust:fix",
    "lint:frontend:fix": "eslint src --fix",
    "lint:rust:fix": "cd src-tauri && cargo fmt && cargo clippy --fix --allow-dirty --allow-staged",
    "format": "pnpm eslint src --fix && cd src-tauri && cargo fmt",
    "tauri": "tauri",
    "version:sync": "node .github/scripts/sync-version.js",
    "release:validate": "node .github/scripts/validate-version.js",
    "supabase:setup": "node scripts/setup-supabase.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@types/turndown": "^5.0.6",
    "lucide-svelte": "^1.0.1",
    "marked": "^18.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
